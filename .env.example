TELEGRAM_CHAT_ID=
TELEGRAM_BOT_TOKEN=
VPN_SUBSCRIPTION_URL=

# Optional: profile name fragment from the subscription, for example SMART or BRIDGE.
VPN_PROFILE_MATCH=

# Optional comma-separated list, for example https://example.com,https://www.example.com.
# Leave empty for same-origin requests through nginx.
CORS_ORIGINS=

RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX=5
MIN_FORM_TIME_MS=1500
MAX_FORM_AGE_MS=86400000
TELEGRAM_TIMEOUT_MS=15000
